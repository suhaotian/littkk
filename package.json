{
  "name": "littkk",
  "version": "1.0.0",
  "description": "A headroom library that hides site headers or footers when scrolling down and reveals them again when scrolling up.",
  "repository": "suhaotian/littkk",
  "bugs": "https://github.com/suhaotian/littkk/issues",
  "homepage": "https://suhaotian.github.io/littkk",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "workspaces": [
    "demos/**",
    "./**"
  ],
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "scripts": {
    "build": "rm -rf dist  && bun build.ts && tsc --emitDeclarationOnly"
  },
  "files": [
    "dist",
    "package.json",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "Headroom",
    "JavaScript",
    "Multiple Headroom"
  ],
  "author": {
    "name": "@suhaotian",
    "url": "https://github.com/suhaotian"
  },
  "license": "MIT"
}
